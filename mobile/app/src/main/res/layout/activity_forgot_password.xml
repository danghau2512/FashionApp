<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="150dp"
            android:layout_height="115dp"
            android:src="@drawable/logo_fashionshop"
            android:scaleType="centerCrop"
            android:adjustViewBounds="false"
            android:layout_gravity="center"
            android:contentDescription="Fashion Shop Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quên mật khẩu"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/auth_text"
            android:layout_marginTop="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhập email đã đăng ký. Firebase sẽ gửi link đặt lại mật khẩu."
            android:textSize="14sp"
            android:textColor="@color/auth_hint"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp" />

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_auth_input"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:textColor="@color/auth_text"
            android:textColorHint="@color/auth_hint"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />

        <Button
            android:id="@+id/btnSendReset"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_auth_button"
            android:backgroundTint="@null"
            android:text="Gửi email đặt lại mật khẩu"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#FFFFFF" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="14dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quay lại đăng nhập"
            android:textColor="@color/auth_primary"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>