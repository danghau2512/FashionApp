<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:background="@color/primary_pink"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/btnBackAdminProductForm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:text="← Quay lại"
                android:textColor="@color/primary_pink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAdminProductFormTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Thêm sản phẩm"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên sản phẩm"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminProductName"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="Nhập tên sản phẩm"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Danh mục"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerAdminProductCategory"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:paddingHorizontal="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Mô tả"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminProductDescription"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:gravity="top"
                android:hint="Nhập mô tả"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Giá"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminProductPrice"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="Ví dụ: 260000"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Giá sale"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminProductSalePrice"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="Có thể để trống"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Image URL"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminProductImageUrl"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="/images/products/..."
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/imgAdminProductPreview"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="10dp"
                android:background="#F5F5F5"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher" />

            <TextView
                android:id="@+id/btnChooseAdminProductImage"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@color/primary_light"
                android:gravity="center"
                android:text="Chọn ảnh sản phẩm"
                android:textColor="@color/primary_pink"
                android:textSize="14sp"
                android:textStyle="bold" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Brand"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminProductBrand"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="FashionShop"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Gender"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerAdminProductGender"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:paddingHorizontal="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Trạng thái"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerAdminProductStatusForm"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:paddingHorizontal="8dp" />

            <TextView
                android:id="@+id/txtAdminProductFormMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text=""
                android:textColor="@color/sale_red"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btnSaveAdminProduct"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@color/primary_pink"
                android:gravity="center"
                android:text="Lưu sản phẩm"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCancelAdminProductForm"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@color/white"
                android:gravity="center"
                android:text="Hủy"
                android:textColor="@color/primary_pink"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>