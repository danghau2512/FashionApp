<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="135dp"
        android:background="@color/primary_pink"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/btnBackAdminVariants"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:paddingHorizontal="12dp"
            android:paddingVertical="7dp"
            android:text="← Quay lại"
            android:textColor="@color/primary_pink"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAdminVariantTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Biến thể sản phẩm"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAdminVariantProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Tên sản phẩm"
            android:textColor="@color/white"
            android:textSize="13sp" />

    </LinearLayout>
    <TextView
        android:id="@+id/btnAddAdminVariant"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_margin="12dp"
        android:background="@color/primary_pink"
        android:gravity="center"
        android:text="+ Thêm biến thể"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtAdminVariantMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Đang tải biến thể..."
        android:textColor="@color/gray_text"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminVariants"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

</LinearLayout>