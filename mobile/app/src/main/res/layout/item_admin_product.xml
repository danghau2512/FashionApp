<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="#EEEEEE"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgAdminProduct"
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:background="#F5F5F5"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtAdminProductName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Tên sản phẩm"
                    android:textColor="@color/dark_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtAdminProductId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="ID: 1"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtAdminProductCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Danh mục: Áo thun"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtAdminProductBrand"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Brand: FashionShop"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtAdminProductStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/primary_light"
                android:paddingHorizontal="8dp"
                android:paddingVertical="5dp"
                android:text="ACTIVE"
                android:textColor="@color/primary_pink"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtAdminProductPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Giá: 260.000đ | Sale: 219.000đ"
            android:textColor="@color/sale_red"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnDetailAdminProduct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/primary_light"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Chi tiết"
                android:textColor="@color/primary_pink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnEditAdminProduct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@color/primary_light"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Sửa"
                android:textColor="@color/primary_pink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnToggleAdminProduct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@color/primary_pink"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="Ẩn"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>