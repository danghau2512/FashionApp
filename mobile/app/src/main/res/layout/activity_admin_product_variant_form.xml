<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:background="@color/primary_pink"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/btnBackAdminVariantForm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="7dp"
                android:text="← Quay lại"
                android:textColor="@color/primary_pink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAdminVariantFormTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Thêm biến thể"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Size"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminVariantSize"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="Ví dụ: M, L, XL"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Màu"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminVariantColor"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="Ví dụ: Đen, Trắng, Xám"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Số lượng"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminVariantQuantity"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="Ví dụ: 20"
                android:inputType="number"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Image URL"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtAdminVariantImageUrl"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:hint="/images/products/..."
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="@color/dark_text"
                android:textColorHint="@color/gray_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Trạng thái"
                android:textColor="@color/dark_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerAdminVariantStatus"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="6dp"
                android:background="@color/white"
                android:paddingHorizontal="8dp" />

            <TextView
                android:id="@+id/txtAdminVariantFormMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text=""
                android:textColor="@color/sale_red"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btnSaveAdminVariant"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@color/primary_pink"
                android:gravity="center"
                android:text="Lưu biến thể"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCancelAdminVariantForm"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@color/white"
                android:gravity="center"
                android:text="Hủy"
                android:textColor="@color/primary_pink"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>